{
  "manifest_version": 3,
  "name": "FreeCustom.Email – Temp Mail & OTP Inbox",
  "version": "2.0",
  "description": "Disposable email, OTP receiver, real-time inbox, and auto OTP fill for signups and testing.",
  "icons": {
    "61": "icon61.png"
  },
  "action": { "default_popup": "index.html" },
  "background": {
    "service_worker": "background.js"
  },
  "permissions": [
    "storage",
    "notifications",
    "unlimitedStorage",
    "tabs"
  ],
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"],
      "run_at": "document_end"
    }
  ]
}